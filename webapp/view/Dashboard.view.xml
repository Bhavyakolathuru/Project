<mvc:View
    controllerName="project1.controller.Dashboard"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Page title="Employee Details">
        <content>

            <VBox class="empContainer" alignItems="Center" justifyContent="Center">

                <VBox class="empBox">

                    <Title text="Employee Form" level="H2" class="empTitle"/>

                    <!-- Name -->
                    <HBox class="empRow" alignItems="Center">
                        <Label text="Employee Name" width="140px"/>
                        <Input id="empName" placeholder="Enter name" width="220px"/>
                    </HBox>

                    <!-- ID -->
                    <HBox class="empRow" alignItems="Center">
                        <Label text="Employee ID" width="140px"/>
                        <Input id="empId" placeholder="Enter ID" width="220px"/>
                    </HBox>

                    <!-- Phone -->
                    <HBox class="empRow" alignItems="Center">
                        <Label text="Phone Number" width="140px"/>
                        <Input id="empPhone" type="Tel" placeholder="Enter phone" width="220px"/>
                    </HBox>

                    <!-- Email -->
                    <HBox class="empRow" alignItems="Center">
                        <Label text="Email" width="140px"/>
                        <Input id="empEmail" type="Email" placeholder="Enter email" width="220px"/>
                    </HBox>

                    <!-- Department -->
                    <HBox class="empRow" alignItems="Center">
                        <Label text="Department" width="140px"/>
                        <Select id="empDept" width="220px">
                            <items>
                                <core:Item key="HR" text="HR"/>
                                <core:Item key="IT" text="IT"/>
                                <core:Item key="Finance" text="Finance"/>
                            </items>
                        </Select>
                    </HBox>

                    <!-- Button -->
                    <HBox justifyContent="Center">
                        <Button 
                            text="Submit"
                            type="Emphasized"
                            class="empButton"
                            press="onSubmit" />
                    </HBox>

                </VBox>

            </VBox>

        </content>
    </Page>

</mvc:View>