<mvc:View
    controllerName="project1.controller.Dashboard"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Page title="Employee Details">
        <content>

            <VBox class="empContainer" alignItems="Center" justifyContent="Center">

                <VBox class="empBox">

                    <Title text="Employee Form" level="H2" class="empTitle"/>

                    <!-- Name -->
                    <Label text="Employee Name" />
                    <Input id="empName" placeholder="Enter name" class="empInput"/>

                    <!-- ID -->
                    <Label text="Employee ID" />
                    <Input id="empId" placeholder="Enter ID" class="empInput"/>

                    <!-- Phone -->
                    <Label text="Phone Number" />
                    <Input id="empPhone" type="Tel" placeholder="Enter phone" class="empInput"/>

                    <!-- Email -->
                    <Label text="Email" />
                    <Input id="empEmail" type="Email" placeholder="Enter email" class="empInput"/>

                    <!-- Department -->
                    <Label text="Department" />
                    <Select id="empDept" class="empInput">
                        <items>
                            <core:Item key="HR" text="HR"/>
                            <core:Item key="IT" text="IT"/>
                            <core:Item key="Finance" text="Finance"/>
                        </items>
                    </Select>

                    <!-- Submit -->
                    <Button 
                        text="Submit"
                        type="Emphasized"
                        class="empButton"
                        press="onSubmit" />

                </VBox>

            </VBox>

        </content>
    </Page>

</mvc:View>